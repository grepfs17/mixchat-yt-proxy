# MixChat YouTube Proxy — Environment Variables

# ── Auth ──
# Required. Shared secret token that MixChat sends as Authorization: Bearer <token>.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_TOKEN=

# ── YouTube InnerTube ──
YT_CLIENT=WEB
YT_DEBUG=0

# Optional — override the default Chrome User-Agent
# YT_USER_AGENT=

# Optional — browser cookie string for authenticated access (strongest anti-403)
# YT_COOKIE=

# Optional — manual PoToken override (skips auto-generation)
# YT_POTOKEN=

# Optional — manual visitor_data override (skips auto-generation)
# YT_VISITOR_DATA=

# Set to "off" to disable automatic PoToken generation
# YT_POTOKEN=off

# Optional — origin URL for Referer header
# ORIGIN=https://www.youtube.com/
# MixChat YouTube Proxy — Environment Variables

# ── Auth ──
# Required. Shared secret token that MixChat sends as Authorization: Bearer <token>.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_TOKEN=

# ── Security ──
# Required. Allowed origin for CORS. Set to your MixChat URL.
# If not set, CORS headers are empty (no browser access allowed).
# CORS_ORIGIN=https://your-mixchat-url.example

# ── YouTube InnerTube ──
YT_CLIENT=WEB
YT_DEBUG=0

# Optional — override the default Chrome User-Agent
# YT_USER_AGENT=

# Optional — browser cookie string for authenticated access (strongest anti-403)
# YT_COOKIE=

# Manual PoToken/visitor_data overrides
# YT_POTOKEN=
# YT_VISITOR_DATA=

# Auto PoToken generation requires JSDOM which does NOT work in Vercel's
# serverless runtime. Only set YT_AUTO_POTOKEN=1 if running on a Node.js
# server with JSDOM support (e.g. a VPS or Docker container).
# YT_AUTO_POTOKEN=1

# Optional — origin URL for Referer header
# ORIGIN=https://www.youtube.com/